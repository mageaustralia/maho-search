<?xml version="1.0"?>
<config>
    <sections>
        <lucenesearch translate="label" module="lucenesearch">
            <label>Lucene Search</label>
            <tab>general</tab>
            <sort_order>350</sort_order>
            <show_in_default>1</show_in_default>
            <show_in_website>1</show_in_website>
            <show_in_store>1</show_in_store>
            <groups>
                <general translate="label">
                    <label>General Settings</label>
                    <sort_order>10</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>1</show_in_website>
                    <show_in_store>1</show_in_store>
                    <fields>
                        <enabled translate="label comment">
                            <label>Enable Lucene Search</label>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <comment>Enable file-based Lucene search. No external services required.</comment>
                        </enabled>
                    </fields>
                </general>

                <products translate="label">
                    <label>Product Search</label>
                    <sort_order>20</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>1</show_in_website>
                    <show_in_store>1</show_in_store>
                    <fields>
                        <enabled translate="label">
                            <label>Index Products</label>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </enabled>
                        <searchable_attributes translate="label comment">
                            <label>Searchable Attributes</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>20</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <comment>Comma-separated attribute codes (e.g. name,sku,description,short_description,manufacturer)</comment>
                        </searchable_attributes>
                        <boost_name translate="label">
                            <label>Name Boost</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>30</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </boost_name>
                        <boost_sku translate="label">
                            <label>SKU Boost</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>40</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </boost_sku>
                        <boost_description translate="label">
                            <label>Description Boost</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>50</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </boost_description>
                        <boost_short_description translate="label">
                            <label>Short Description Boost</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>60</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </boost_short_description>
                        <index_category_paths translate="label">
                            <label>Index Category Paths</label>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <sort_order>70</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </index_category_paths>
                        <boost_category_paths translate="label">
                            <label>Category Paths Boost</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>80</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </boost_category_paths>
                    </fields>
                </products>

                <categories translate="label">
                    <label>Category Search</label>
                    <sort_order>30</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>1</show_in_website>
                    <show_in_store>1</show_in_store>
                    <fields>
                        <enabled translate="label">
                            <label>Index Categories</label>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </enabled>
                        <searchable_attributes translate="label comment">
                            <label>Searchable Attributes</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>15</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <comment>Comma-separated attribute codes (e.g. name,description,meta_title,meta_keywords,meta_description)</comment>
                        </searchable_attributes>
                        <boost_name translate="label">
                            <label>Name Boost</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>20</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </boost_name>
                        <boost_description translate="label">
                            <label>Description Boost</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>30</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </boost_description>
                        <boost_meta_title translate="label">
                            <label>Meta Title Boost</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>40</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </boost_meta_title>
                        <boost_meta_keywords translate="label">
                            <label>Meta Keywords Boost</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>50</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </boost_meta_keywords>
                        <boost_meta_description translate="label">
                            <label>Meta Description Boost</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>60</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </boost_meta_description>
                    </fields>
                </categories>

                <cms translate="label">
                    <label>CMS Page Search</label>
                    <sort_order>40</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>1</show_in_website>
                    <show_in_store>1</show_in_store>
                    <fields>
                        <enabled translate="label">
                            <label>Index CMS Pages</label>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                        </enabled>
                        <searchable_attributes translate="label comment">
                            <label>Searchable Attributes</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>15</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <comment>Comma-separated field names (e.g. title,content,content_heading,meta_keywords,meta_description)</comment>
                        </searchable_attributes>
                        <excluded_pages translate="label comment">
                            <label>Excluded Pages</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>20</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <comment>Comma-separated page identifiers to exclude (e.g. no-route,enable-cookies,privacy-policy)</comment>
                        </excluded_pages>
                        <boost_title translate="label">
                            <label>Title Boost</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>30</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </boost_title>
                        <boost_content translate="label">
                            <label>Content Boost</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>40</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </boost_content>
                        <boost_content_heading translate="label">
                            <label>Content Heading Boost</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>50</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </boost_content_heading>
                        <boost_meta_keywords translate="label">
                            <label>Meta Keywords Boost</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>60</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </boost_meta_keywords>
                        <boost_meta_description translate="label">
                            <label>Meta Description Boost</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>70</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </boost_meta_description>
                    </fields>
                </cms>

                <search translate="label">
                    <label>Search Settings</label>
                    <sort_order>50</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>1</show_in_website>
                    <show_in_store>1</show_in_store>
                    <fields>
                        <result_limit translate="label comment">
                            <label>Max Results</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                            <comment>Maximum search results to return (0 = unlimited)</comment>
                        </result_limit>
                        <suggest_limit translate="label">
                            <label>Suggest Limit</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>20</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </suggest_limit>
                        <fuzzy_fallback translate="label comment">
                            <label>Enable Fuzzy Fallback</label>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <sort_order>30</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                            <comment>When no exact results found, retry with fuzzy matching</comment>
                        </fuzzy_fallback>
                        <similarity translate="label comment">
                            <label>Scoring Algorithm</label>
                            <frontend_type>select</frontend_type>
                            <source_model>lucenesearch/system_config_source_similarity</source_model>
                            <sort_order>32</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                            <comment><![CDATA[<b>TF-IDF</b> = classic Lucene scoring. <b>BM25</b> = saturating term frequency, used by Elasticsearch/Solr — generally better relevance for product search. <b>Reindex required after switching.</b>]]></comment>
                        </similarity>
                        <bm25_k1 translate="label comment">
                            <label>BM25 k1 (TF saturation)</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>33</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                            <comment>Default 1.2. Higher values make repeated terms count for more.</comment>
                            <depends><similarity>bm25</similarity></depends>
                        </bm25_k1>
                        <bm25_b translate="label comment">
                            <label>BM25 b (length normalization)</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>34</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                            <comment>Default 0.75. 0 = no length penalty, 1 = full penalty for long fields.</comment>
                            <depends><similarity>bm25</similarity></depends>
                        </bm25_b>
                        <bm25_avg_field_length translate="label comment">
                            <label>BM25 Avg Field Length</label>
                            <frontend_type>text</frontend_type>
                            <sort_order>35</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                            <comment>Approximate average tokens per indexed field. Default 10 (suits product names). Raise for description-heavy catalogs.</comment>
                            <depends><similarity>bm25</similarity></depends>
                        </bm25_avg_field_length>
                        <synonyms translate="label comment">
                            <label>Synonym Groups</label>
                            <frontend_type>textarea</frontend_type>
                            <sort_order>40</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>1</show_in_website>
                            <show_in_store>1</show_in_store>
                            <comment><![CDATA[One group per line, comma-separated terms. Requires reindex after changes.<br/>Example:<br/>jean, jeans, denim<br/>tee, t-shirt, tshirt<br/>sneaker, runner, trainer]]></comment>
                        </synonyms>
                    </fields>
                </search>
            </groups>
        </lucenesearch>
    </sections>
</config>
